# ============================================================
# FlowFi Backend — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# JWT
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_STRONG_SECRET
JWT_REFRESH_EXPIRES_IN=30d

# Supabase
SUPABASE_URL="https://spcfuxqwxkumreknzajo.supabase.co"
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNwY2Z1eHF3eGt1bXJla256YWpvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU1NDc1MjcsImV4cCI6MjA5MTEyMzUyN30.gkX8FZAgQ4prv2YyrhVUzr1TebtQbG2WbcEPA2Kn80Y"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNwY2Z1eHF3eGt1bXJla256YWpvIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NTU0NzUyNywiZXhwIjoyMDkxMTIzNTI3fQ.pQ0gr9I9kTeXV-cuIjZgfEWo_nabota7BYmZo2QC37k"

# M-Pesa (Safaricom Daraja API)
MPESA_CONSUMER_KEY=YOUR_MPESA_CONSUMER_KEY
MPESA_CONSUMER_SECRET=YOUR_MPESA_CONSUMER_SECRET
MPESA_SHORTCODE=YOUR_MPESA_SHORTCODE
MPESA_PASSKEY=YOUR_MPESA_PASSKEY
MPESA_CALLBACK_URL=https://yourdomain.com/api/payments/mpesa/callback
MPESA_ENV=sandbox
# Set MPESA_ENV=production for live

# Paystack
PAYSTACK_SECRET_KEY=sk_test_YOUR_PAYSTACK_SECRET_KEY
PAYSTACK_PUBLIC_KEY=pk_test_YOUR_PAYSTACK_PUBLIC_KEY
PAYSTACK_WEBHOOK_SECRET=YOUR_PAYSTACK_WEBHOOK_SECRET

# Email (Nodemailer — use Gmail, Mailgun, etc.)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your@gmail.com
EMAIL_PASS=YOUR_APP_PASSWORD
EMAIL_FROM="FlowFi <noreply@flowfi.co.ke>"

# SMS (Africa's Talking — most popular in Kenya)
AT_API_KEY=YOUR_AFRICASTALKING_API_KEY
AT_USERNAME=YOUR_AFRICASTALKING_USERNAME
AT_SENDER_ID=FlowFi

# MikroTik (platform-level defaults, tenants override)
MIKROTIK_DEFAULT_PORT=8728

# Platform Commission
DEFAULT_COMMISSION_PERCENT=5

# Scheduled Jobs
CRON_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET

# Super Admin Bootstrap (used only on first run)
SUPER_ADMIN_EMAIL=admin@flowfi.co.ke
SUPER_ADMIN_PASSWORD=CHANGE_THIS_IMMEDIATELY
